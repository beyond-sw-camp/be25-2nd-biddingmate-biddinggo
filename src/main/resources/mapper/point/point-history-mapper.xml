<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.biddingmate.biddinggo.point.mapper.PointHistoryMapper">

    <insert id="insert" parameterType="PointHistory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO point_history (
            member_id,
            payment_id,
            bid_id,
            type,
            amount,
            created_at
        )
        VALUES (
                   #{memberId},
                   #{paymentId},
                   #{bidId},
                   #{type},
                   #{amount},
                   #{createdAt}
               );
    </insert>

</mapper>